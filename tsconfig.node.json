{
    "extends": "@tsconfig/node22/tsconfig.json",
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo", "target": "es2023",
        "lib": ["ES2023"],
        "moduleDetection": "force",
        "module": "esnext",
        "moduleResolution": "Bundler",
        "paths": {
            "#/*": ["./types/*"]
        },
        "types": ["node"],
        "allowImportingTsExtensions": true,

        "noFallthroughCasesInSwitch": true,
        /* Linting */
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noEmit": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true,
        "erasableSyntaxOnly": true
    },
    "include": [
        "scripts/**/*.ts",
        "scripts/**/*.d.ts",
        "vite.config.*",
        "vitest.config.*",
        "cypress.config.*",
        "nightwatch.conf.*",
        "playwright.config.*",
        "uno.config.ts"
    ]
}